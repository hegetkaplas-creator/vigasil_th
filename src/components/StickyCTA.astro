---
import MiniCTA from "./MiniCTA.astro";
---

<div class="sticky-cta-anchor">
  <MiniCTA instance="stickycta" embed />
</div>

<style>
  .sticky-cta-anchor {
    position: sticky;
    bottom: 0;
    z-index: 18;
    padding: 12px 0 16px;
    margin-top: 8px;
    pointer-events: none;
  }

  .sticky-cta-anchor :global(.mini-cta--embed) {
    pointer-events: auto;
    max-width: var(--container);
    margin: 0 auto;
    width: min(var(--container), calc(100% - 28px));
  }
</style>

<section class="section" id="real-comments">
  <div class="container">
    <div class="section-card glass-strong">
      <div class="comments-section">
        <h3 style="font-size: 18px; margin-bottom: 24px;">ความคิดเห็น (48)</h3>

        <div class="comments-scroll" id="comments-scroll">
          <div id="comments-container">
            <div class="comment-item">
              <div class="comment-avatar">ช</div>
              <div class="comment-body">
                <div class="comment-author">ชยุต เขมสุวรรณ</div>
                <div class="comment-text">ใครที่กินไวอาก้ามาก่อน มักจะชอบบอกว่าพวกอาหารเสริมไม่ได้ผล ทั้งๆที่ยังไม่เคยลองเลยแม้แต่ครั้งเดียว อยากให้ลองเปิดใจดูครับ</div>
                <div class="comment-meta">ถูกใจ · ตอบกลับ · 12 นาทีที่แล้ว</div>
              </div>
            </div>

            <div class="comment-item">
              <div class="comment-avatar">ว</div>
              <div class="comment-body">
                <div class="comment-author">วราภพ พินิจไพศาล</div>
                <div class="comment-text">ไม่รู้ว่าจะได้ผลหรือเปล่าเพราะว่าผมลองมาหลายตัวแล้วรวมถึงไวอากร้าด้วย ปรึกษาหมอมาแล้วหลายคลินิก ก็ไม่ได้ผล จะทำยังไงดีครับ????</div>
                <div class="comment-meta">ถูกใจ · ตอบกลับ · 34 นาทีที่แล้ว</div>

                <div class="comment-item" style="margin-top: 12px;">
                  <div class="comment-avatar" style="width: 32px; height: 32px; font-size: 12px;">ป</div>
                  <div class="comment-body">
                    <div class="comment-author">ปัญญา ฐานนครบำนาญ</div>
        <div class="comment-text">อยากให้ลอง Vigasil ดูนะครับ ไม่ลองไม่รู้หรอกครับ ส่วนตัวผมเองตอนแรกก็คิดว่ามันคงไม่ได้ผล ผมเองก็กินไวอากร้ามาเกือบปีนึง ไม่โอเคเลย แต่มาเจอ Vigasil ทำให้ผมกลับมาแข็งตัวได้โดยไม่ต้องพึ่งยา มี CBD ช่วยให้ผ่อนคลายและคงผลลัพธ์ได้ดีขึ้นด้วย</div>
                    <div class="comment-meta">ถูกใจ (4) · ตอบกลับ · 20 นาทีที่แล้ว</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="comment-item">
              <div class="comment-avatar">ต</div>
              <div class="comment-body">
                <div class="comment-author">ตระกูล เลิศสกุล</div>
                <div class="comment-text">บอกเลยว่าจริงครับ ไซส์ของผมจากเมื่อก่อนแค่ 49 นิ้ว ตอนนี้เพิ่มมาเป็น 52 สุดยอดมาก!</div>
                <div class="comment-meta">ถูกใจ · ตอบกลับ · 1 ชั่วโมงที่แล้ว</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const commentsData = [
    { author: "เมฆพันธ์ ชาโอภาศ", text: "ผมเองก็ลองมาหลายอย่างนะ แต่ไม่ได้ผล เพราะหลังจากที่เพื่อนให้ Vigasil มากระปุกนึง เริ่มเห็นผลเลย ชอบมากครับ ตอนนี้กำลังหาซื้อเอง เห็นว่ามีโปรโมชั่นด้วย ต้องจัด!", time: "เมื่อสักครู่" },
    { author: "คุณ ชายชา", text: "อาหารเสริมตัวนี้มีคุณสมบัติเด่นกว่าตัวอื่น ผมการันตีด้วยตัวเอง เพราะมีส่วนผสมของ CBD เข้ามาเป็นตัวช่วยเรื่องการไหลเวียนโลหิต ส่วนตัวผมทานมาแล้ว 6 เดือน ประทับใจมากครับ", time: "เมื่อสักครู่" },
    { author: "เคน ธีรดล", text: "Vigasil ได้ใจผมกับแฟนไปเต็มๆ เต็ม 10 ไม่หักครับ", time: "เมื่อสักครู่" },
    { author: "กิตติธร ณามาก", text: "ถ้าไม่ได้ผลจริง คงไม่ขายดีขนาดนี้ แนะนำเลยครับ", time: "เมื่อสักครู่" },
    { author: "ปองภพ สมหมายมั่น", text: "เรื่องบนเตียงแก้ได้ด้วย Vigasil เท่านั้นครับ", time: "เมื่อสักครู่" },
      { author: "ฟ้าใส นงนาถ", text: "อยากได้ผลลัพธ์ที่สม่ำเสมอไม่ต่ำกว่าอาทิตย์ละ 4 วัน แนะนำ Vigasil ค่ะ เพราะเราก็ซื้อให้สามีเหมือนกัน", time: "เมื่อสักครู่" }
  ];

  function getAvatarInitial(author) {
    if (!author) return "?";
    const cleaned = author.replace("คุณ ", "").trim();
    return cleaned.charAt(0) || "?";
  }

  function addRandomComment() {
    if (commentsData.length === 0) return;
    const container = document.getElementById('comments-container');
    const scrollBox = document.getElementById('comments-scroll');
    if (!container || !scrollBox) return;
    const shouldStickToBottom =
      (scrollBox.scrollTop + scrollBox.clientHeight >= scrollBox.scrollHeight - 20);
    const data = commentsData.shift();
    const commentDiv = document.createElement('div');
    commentDiv.className = 'comment-item';
    commentDiv.style.opacity = '0';
    commentDiv.style.transform = 'translateY(10px)';
    commentDiv.style.transition = 'all 0.5s ease';
    const initial = getAvatarInitial(data.author);
    commentDiv.innerHTML = `
      <div class="comment-avatar">${initial}</div>
      <div class="comment-body">
        <div class="comment-author">${data.author}</div>
        <div class="comment-text">${data.text}</div>
        <div class="comment-meta">ถูกใจ · ตอบกลับ · ${data.time}</div>
      </div>
    `;
    container.append(commentDiv);

    const topLevelComments = container.querySelectorAll(':scope > .comment-item');
    const MAX_VISIBLE_COMMENTS = 24;
    if (topLevelComments.length > MAX_VISIBLE_COMMENTS) {
      topLevelComments[0].remove();
    }

    setTimeout(() => {
      commentDiv.style.opacity = '1';
      commentDiv.style.transform = 'translateY(0)';
      if (shouldStickToBottom) {
        scrollBox.scrollTop = scrollBox.scrollHeight;
      }
    }, 100);
    setTimeout(addRandomComment, Math.floor(Math.random() * 15000) + 10000);
  }
  setTimeout(addRandomComment, 5000);
</script>

<style>
  .comments-section { margin-top: 0; padding-top: 0; border-top: 0; }
  .comments-scroll { max-height: clamp(320px, 44vh, 460px); overflow-y: auto; overscroll-behavior: contain; padding-right: 6px; }
  .comments-scroll::-webkit-scrollbar { width: 10px; }
  .comments-scroll::-webkit-scrollbar-thumb { border-radius: 999px; background: rgba(13,148,136,.28); border: 2px solid rgba(255,255,255,.65); }
  .comments-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,.45); border-radius: 999px; }
  .comment-item { display: flex; gap: 12px; margin-bottom: 20px; }
  .comment-avatar { width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #14b8a6, #0d9488); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; flex-shrink: 0; }
  .comment-body { background: rgba(0,0,0,0.04); padding: 12px 16px; border-radius: 18px; max-width: 85%; }
  .comment-author { font-weight: 700; font-size: 13px; color: var(--text); margin-bottom: 2px; }
  .comment-text { font-size: 14px; line-height: 1.4; color: var(--text); }
  .comment-meta { font-size: 11px; color: var(--text-dim); margin-top: 4px; padding-left: 4px; }

  @media (max-width: 720px) { .comments-scroll { max-height: min(54vh, 360px); } }
</style>

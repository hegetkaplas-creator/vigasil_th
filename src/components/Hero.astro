<script is:inline>
  (function () {
    var nameF = document.getElementById("hero-inline-name");
    var phoneF = document.getElementById("hero-inline-phone");
    var submitBtn = document.getElementById("heroInlineSubmitBtn");
    var formWrap = document.getElementById("heroInlineFormWrap");
    var thankYou = document.getElementById("heroInlineThankYou");

    if (!nameF || !phoneF || !submitBtn || !formWrap || !thankYou) return;

    phoneF.addEventListener("input", function () {
      var hasPlus = this.value.startsWith("+");
      var val = this.value.replace(/\D/g, "");
      if (val.length > 15) val = val.slice(0, 15);
      this.value = hasPlus ? "+" + val : val;
    });

    function showHeroThankYou() {
      formWrap.setAttribute("hidden", "");
      thankYou.removeAttribute("hidden");
    }

    submitBtn.addEventListener("click", function () {
      var name = nameF.value.trim();
      var phone = phoneF.value.trim();
      var digits =
        typeof getDigitsOnly === "function" ? getDigitsOnly(phone) : phone.replace(/\D/g, "");
      var hasError = false;

      if (!name) {
        nameF.style.borderColor = "var(--danger)";
        hasError = true;
      } else {
        nameF.style.borderColor = "";
      }

      if (!digits || digits.length < 9 || digits.length > 15) {
        phoneF.style.borderColor = "var(--danger)";
        hasError = true;
      } else {
        phoneF.style.borderColor = "";
      }

      if (hasError) return;

      var cfg = window.FORM_CONFIG || {};
      var endpoint =
        cfg.formEndpoint || (document.body && document.body.getAttribute("data-form-endpoint")) || "";
      var formId = cfg.formId || (document.body && document.body.getAttribute("data-form-id")) || "transit";
      var method = (
        cfg.formMethod ||
        (document.body && document.body.getAttribute("data-form-method")) ||
        "POST"
      ).toUpperCase();
      var debug =
        typeof URLSearchParams !== "undefined" &&
        new URLSearchParams(window.location.search).get("debugForm") === "1";

      if (!endpoint) {
        console.error("[hero-inline-form] FORM_CONFIG.formEndpoint is empty — check data-form-endpoint on <body>");
        return;
      }

      var original = submitBtn.textContent;
      submitBtn.textContent = "กำลังส่ง...";
      submitBtn.disabled = true;

      var payload = new URLSearchParams();
      payload.set("name", name);
      payload.set("phone", digits);
      payload.set("form_id", formId);

      if (debug) console.log("[hero-inline-form] POST", endpoint, { name: name, phone: digits, form_id: formId });

      function onLeadSentOk() {
        if (typeof fireSuccessPixel === "function") fireSuccessPixel();
        showHeroThankYou();
      }

      fetch(endpoint, {
        method: method,
        headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" },
        body: payload.toString(),
        mode: "cors",
        credentials: "omit",
      })
        .then(function (r) {
          if (debug) console.log("[hero-inline-form] fetch status", r.status, r.ok);
          if (!r.ok) throw new Error("http-" + r.status);
          onLeadSentOk();
        })
        .catch(function (err) {
          if (debug) console.warn("[hero-inline-form] fetch failed, trying iframe fallback", err && err.message);
          var fb = document.getElementById("hero-fallback-form");
          if (fb && endpoint) {
            fb.method = method;
            fb.action = endpoint;
            fb.querySelector('[name="name"]').value = name;
            fb.querySelector('[name="phone"]').value = digits;
            fb.querySelector('[name="form_id"]').value = formId;
            fb.submit();
            onLeadSentOk();
          } else {
            submitBtn.textContent = "ส่งไม่สำเร็จ ลองใหม่อีกครั้ง";
            submitBtn.disabled = false;
            setTimeout(function () {
              submitBtn.textContent = original;
            }, 2500);
          }
        });
    });
  })();
</script>


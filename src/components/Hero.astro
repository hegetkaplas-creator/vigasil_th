<script is:inline>
(function () {
  var overlay = document.getElementById("orderModal");
  var openBtn = document.getElementById("openModalBtn");
  var closeBtn = document.getElementById("closeModalBtn");
  if (!overlay || !openBtn) return;

  function openModal(triggerEl) {
    var top = 80;
    if (triggerEl && triggerEl.getBoundingClientRect) {
      var r = triggerEl.getBoundingClientRect();
      var scrollY = window.pageYOffset || document.documentElement.scrollTop;
      top = Math.max(20, r.top + scrollY - 40);
    }
    overlay.style.height = Math.max(document.documentElement.scrollHeight, document.body.scrollHeight) + "px";
    overlay.style.setProperty("--modal-top", top + "px");
    overlay.classList.add("open");
    overlay.setAttribute("aria-hidden", "false");
  }
  function closeModal() {
    if (overlay.contains(document.activeElement)) {
      try {
        document.activeElement.blur();
      } catch (_) {}
    }
    overlay.classList.remove("open");
    overlay.setAttribute("aria-hidden", "true");
  }

  openBtn.addEventListener("click", function () { openModal(openBtn); });
  closeBtn.addEventListener("click", closeModal);
  overlay.addEventListener("click", function (e) {
    if (e.target === overlay) closeModal();
  });

  document.querySelectorAll('a[href="#order-form"], button[data-open-modal]').forEach(function (el) {
    el.addEventListener("click", function (e) { e.preventDefault(); openModal(el); });
  });

  var nameF = document.getElementById("modal-name");
  var phoneF = document.getElementById("modal-phone");
  var submitBtn = document.getElementById("modalSubmitBtn");

  phoneF.addEventListener("input", function () {
    var hasPlus = this.value.startsWith("+");
    var val = this.value.replace(/\D/g, "");
    if (val.length > 15) val = val.slice(0, 15);
    this.value = hasPlus ? "+" + val : val;
  });

  function showModalThankYou() {
    var card = document.querySelector(".modal-card");
    var ty = document.getElementById("modalThankYou");
    if (card && ty) {
      Array.from(card.children).forEach(function (ch) {
        if (ch.id !== "modalThankYou" && !ch.classList.contains("modal-close"))
          ch.style.display = "none";
      });
      ty.style.display = "flex";
    }
  }

  submitBtn.addEventListener("click", function () {
    var name = nameF.value.trim();
    var phone = phoneF.value.trim();
    var digits = (typeof getDigitsOnly === "function") ? getDigitsOnly(phone) : phone.replace(/\D/g, "");
    var hasError = false;

    if (!name) { nameF.style.borderColor = "var(--danger)"; hasError = true; }
    else { nameF.style.borderColor = ""; }

    if (!digits || digits.length < 9 || digits.length > 15) { phoneF.style.borderColor = "var(--danger)"; hasError = true; }
    else { phoneF.style.borderColor = ""; }

    if (hasError) return;

    var cfg = window.FORM_CONFIG || {};
    var endpoint =
      cfg.formEndpoint ||
      (document.body && document.body.getAttribute("data-form-endpoint")) ||
      "";
    var formId = cfg.formId || (document.body && document.body.getAttribute("data-form-id")) || "transit";
    var method = (
      cfg.formMethod ||
      (document.body && document.body.getAttribute("data-form-method")) ||
      "POST"
    ).toUpperCase();
    var debug = typeof URLSearchParams !== "undefined" && new URLSearchParams(window.location.search).get("debugForm") === "1";

    if (!endpoint) {
      console.error("[order-modal] FORM_CONFIG.formEndpoint is empty — check data-form-endpoint on <body>");
      return;
    }

    var original = submitBtn.textContent;
    submitBtn.textContent = "กำลังส่ง...";
    submitBtn.disabled = true;

    var payload = new URLSearchParams();
    payload.set("name", name);
    payload.set("phone", digits);
    payload.set("form_id", formId);

    if (debug) console.log("[order-modal] POST", endpoint, { name: name, phone: digits, form_id: formId });

    function onLeadSentOk() {
      if (typeof fireSuccessPixel === "function") fireSuccessPixel();
      showModalThankYou();
    }

    fetch(endpoint, {
      method: method,
      headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" },
      body: payload.toString(),
      mode: "cors",
      credentials: "omit"
    })
      .then(function (r) {
        if (debug) console.log("[order-modal] fetch status", r.status, r.ok);
        if (!r.ok) throw new Error("http-" + r.status);
        onLeadSentOk();
      })
      .catch(function (err) {
        if (debug) console.warn("[order-modal] fetch failed, trying iframe fallback", err && err.message);
        var fb = document.getElementById("modal-fallback-form");
        if (fb && endpoint) {
          fb.method = method;
          fb.action = endpoint;
          fb.querySelector('[name="name"]').value = name;
          fb.querySelector('[name="phone"]').value = digits;
          fb.querySelector('[name="form_id"]').value = formId;
          fb.submit();
          onLeadSentOk();
        } else {
          submitBtn.textContent = "ส่งไม่สำเร็จ ลองใหม่อีกครั้ง";
          submitBtn.disabled = false;
          setTimeout(function () { submitBtn.textContent = original; }, 2500);
        }
      });
  });
})();
</script>


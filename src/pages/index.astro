---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

import Topline from '../components/Topline.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Problems from '../components/Problems.astro';
import Mechanism from '../components/Mechanism.astro';
import Ingredients from '../components/Ingredients.astro';
import Comparison from '../components/Comparison.astro';
import Offer from '../components/Offer.astro';
import Timeline from '../components/Timeline.astro';
import Regulatory from '../components/Regulatory.astro';
import VideoFeedback from '../components/VideoFeedback.astro';
import ClientResults from '../components/ClientResults.astro';
import MiniCTA from '../components/MiniCTA.astro';
import Comments from '../components/Comments.astro';
import OrderForm from '../components/OrderForm.astro';
import DeliveryFaq from '../components/DeliveryFaq.astro';
import Footer from '../components/Footer.astro';
---

<Base title="CBD Vigasil — เสริมสมรรถภาพชาย สูตร Double Action">
  <div class="page">
    <Topline />
    <Hero />
    <TrustStrip />
    <Problems />
    <VideoFeedback />
    <OrderForm />
    <Comparison />
    <Mechanism />
    <Ingredients />
    <Regulatory />
    <Timeline />
    <ClientResults />
    <MiniCTA instance="page" />
    <Comments />
    <Offer />
    <OrderForm />
    <DeliveryFaq />
    <Footer />
  </div>
</Base>

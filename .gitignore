# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / AI agent configs (local only, never deploy) ──────────────
.cursor/
.clinerules
.roo/
.cline/
.windsurf/

# ── Cloudflare / Wrangler ────────────────────────────────────────────
.wrangler/

# ── Node ──────────────────────────────────────────────────────────────
node_modules/

# ── Astro build output ───────────────────────────────────────────────
dist/
.astro/

# ── Legacy asset path (now in public/assets/) ────────────────────────
/assets/

# ── Local-only media (raster + video) — not versioned ────────────────
# Clone / CI will not have these files; add them locally or host via CDN/R2.
# SVG is not listed so small vector icons can still be committed if needed.
public/assets/**/*.png
public/assets/**/*.jpg
public/assets/**/*.jpeg
public/assets/**/*.webp
public/assets/**/*.gif
public/assets/**/*.mp4
public/assets/**/*.webm

# ── QA artifacts ──────────────────────────────────────────────────────
.playwright-mcp/
*-smoke-*.png

# ── Design source files (for dev context only, not deployed) ──────────
**/*.psd
**/*.ai
**/*.sketch
**/*.fig
**/*.xd
**/*.mov
**/*.MOV
**/*.avi
assets/Packaging/

# ── Product / internal docs (for dev context only, not deployed) ───────
docs/
_source/
design/
source/
reference/

# ── Draft / scratch pages ─────────────────────────────────────────────
*_raw.html
*_draft.html
*_old.html

.dev.vars*
!.dev.vars.example
.env*
!.env.example

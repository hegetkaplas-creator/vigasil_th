# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / AI agent configs (local only, never deploy) ──────────────
.cursor/
.clinerules
.roo/
.cline/
.windsurf/

# ── Cloudflare / Wrangler (managed manually per project) ──────────────
.wrangler/
wrangler.toml
src/
.github/

# ── Node ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── QA artifacts ──────────────────────────────────────────────────────
.playwright-mcp/

# ── Design source files (for dev context only, not deployed) ──────────
# Photoshop, Illustrator, Sketch, Figma exports, XD
**/*.psd
**/*.ai
**/*.sketch
**/*.fig
**/*.xd
# Raw video from phone / footage (not the optimised web video)
**/*.mov
**/*.MOV
**/*.avi
# Packaging fonts (not web fonts — web fonts go in assets/fonts/)
assets/Packaging/

# ── Product / internal docs (for dev context only, not deployed) ───────
docs/
_source/
design/
source/
reference/

# ── Draft / scratch pages ─────────────────────────────────────────────
*_raw.html
*_draft.html
*_old.html

.dev.vars*
!.dev.vars.example
.env*
!.env.example
